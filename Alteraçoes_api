// Rota para remover o produto do carrinho
if (url.pathname === '/carrinho/remover' && request.method === 'POST') {
    try {
        const body = await request.json();
        const id_produto = body.id_produto;

        if (!id_produto) {
            return new Response(JSON.stringify({ erro: "ID do produto não informado." }), { status: 400 });
        }

        // Aqui está a mágica: Volta o campo carrinho para 0 na tabela tb_estoque
        const info = await env.SEU_BANCO_D1.prepare(
            "UPDATE tb_estoque SET carrinho = 0 WHERE id_estoque = ?"
        ).bind(id_produto).run();

        return new Response(JSON.stringify({ sucesso: true, mensagem: "Produto removido do carrinho!" }), {
            headers: { 'Content-Type': 'application/json' }
        });

    } catch (error) {
        return new Response(JSON.stringify({ erro: error.message }), { status: 500 });
    }
}
